# Private keys and certificates — NEVER to git
*.key
*.pem
*.csr
*.p12
*.pfx
*.crt
!docs/captures/*.pem   # exception: public certs in docs, if present
docs/captures/*keys*.log

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
.pytest_cache/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Models (large binaries)
ml/models/*.joblib

# Wireshark
docs/captures/*.pcap.tmp