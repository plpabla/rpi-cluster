# Force LF line endings for all text files
* text=auto eol=lf

# Explicitly declare common text files
*.py text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.conf text eol=lf
*.txt text eol=lf
*.json text eol=lf

# Declare binary files to avoid mangling
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.gz binary
*.zip binary
